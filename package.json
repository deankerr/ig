{
  "name": "ig",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@cloudflare/workers-types": "^4.20260301.1",
      "@libsql/client": "0.17.0",
      "@orpc/client": "^1.12.2",
      "@orpc/openapi": "^1.13.6",
      "@orpc/server": "^1.13.6",
      "@orpc/zod": "^1.13.6",
      "@types/node": "^25.3.3",
      "@types/uuid": "^11.0.0",
      "alchemy": "^0.87.0",
      "dotenv": "^17.2.4",
      "drizzle-orm": "^0.45.1",
      "hono": "^4.12.3",
      "libsql": "0.5.22",
      "remeda": "^2.33.5",
      "typescript": "^5.9.3",
      "up-fetch": "^2.5.1",
      "uuid": "^13.0.0",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "check": "bun run check-types && oxlint --fix --type-aware apps packages && oxfmt --write apps packages",
    "check-types": "turbo check-types",
    "clean": "rm -rf node_modules .turbo apps/*/node_modules packages/*/node_modules packages/*/dist apps/*/dist && find . -name '*.tsbuildinfo' -not -path '*/node_modules/*' -delete",
    "db:generate": "bun --cwd packages/db db:generate",
    "deploy": "turbo deploy",
    "destroy": "turbo -F @ig/infra destroy",
    "dev:web": "turbo -F web dev"
  },
  "dependencies": {
    "@ig/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@ig/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.0",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "0.15.0",
    "shadcn": "^3.8.5",
    "turbo": "^2.8.11",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
