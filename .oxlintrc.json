{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "react-perf", "promise", "import"],
  "ignorePatterns": [
    ".agents/skills",
    ".claude/skills",
    "**/.alchemy",
    "**/_generated",
    "**/routeTree.gen.ts",
    "**/components/ui"
  ],
  "rules": {
    "typescript/triple-slash-reference": "off"
  }
}
